# Server
PORT=5000

# Comma-separated list of allowed browser origins
# Examples:
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# 3000 = Admin (CRA), 3001 = Customer (Next.js)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# Optional: seed/reset default admin via `npm run seed-admin`
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_MOBILE=

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_PORT=3306
DB_NAME=ecommerce

# Uploads: auto|local|s3
UPLOAD_DRIVER=auto
UPLOAD_LOCAL_DIR=uploads
UPLOAD_PUBLIC_PATH=/uploads

# S3 (only needed if UPLOAD_DRIVER=s3 or auto with creds present)
AWS_S3_BUCKET=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OTP / Forgot password
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MIN_SECONDS_BETWEEN_REQUESTS=60
OTP_MAX_PER_HOUR=5

# SMS delivery: console|fast2sms
SMS_PROVIDER=console

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# DEV ONLY (never enable in production): return OTP in API response
OTP_DEBUG_RETURN=false

# Fast2SMS (only if SMS_PROVIDER=fast2sms)
FAST2SMS_API_KEY=
# Optional Fast2SMS params
FAST2SMS_ROUTE=q
FAST2SMS_LANGUAGE=
FAST2SMS_SENDER_ID=
